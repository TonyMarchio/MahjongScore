{
  "expo": {
    "name": "Mahjong Vision",
    "slug": "MahjongScore",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mahjongscore",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.anthonymarchio.mahjongscore",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSSupportsOpeningDocumentsInPlace": false,
        "NSCameraUsageDescription": "Used to scan and identify mahjong tiles for scoring",
        "NSPhotoLibraryUsageDescription": "Used to select saved tile images for recognition",
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Mahjong Tile Set",
            "CFBundleTypeRole": "Editor",
            "LSHandlerRank": "Owner",
            "LSItemContentTypes": ["com.anthonymarchio.mahjongscore.tileset"]
          }
        ],
        "UTExportedTypeDeclarations": [
          {
            "UTTypeConformsTo": ["public.data", "public.content"],
            "UTTypeDescription": "Mahjong Tile Set",
            "UTTypeIdentifier": "com.anthonymarchio.mahjongscore.tileset",
            "UTTypeTagSpecification": {
              "public.filename-extension": ["mahjongset"],
              "public.mime-type": "application/x-mahjongset"
            }
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-image-picker",
      ["expo-build-properties", {
        "ios": {
          "deploymentTarget": "16.0"
        }
      }],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "de56144f-3560-49c0-bc65-a1239b4db7cb"
      }
    }
  }
}
